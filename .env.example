# OCOM - OpenClaw Multi-Account Provider
PORT=3001
NODE_ENV=development
DATABASE_PATH=./data/ocom.db
MASTER_KEY=change-me-in-production-please-32bytes-min
LOG_LEVEL=info
AUDIT_HMAC_KEY=change-me-audit-hmac-secret

# OAuth PKCE (provider-specific)
# Provider key format: OAUTH_<PROVIDER>_... where non-alnum chars become '_' (e.g. openai-codex -> OPENAI_CODEX)
# Required for start/callback:
# OAUTH_OPENAI_CODEX_CLIENT_ID=
# OAUTH_OPENAI_CODEX_AUTH_URL=
# OAUTH_OPENAI_CODEX_REDIRECT_URI=http://127.0.0.1:3001/oauth/openai-codex/callback
# Optional:
# OAUTH_OPENAI_CODEX_SCOPES=openid profile email
# OAUTH_OPENAI_CODEX_TOKEN_URL=
# OAUTH_OPENAI_CODEX_CLIENT_SECRET=

# Token refresh worker
# TOKEN_REFRESH_INTERVAL_MS=300000

# Health scoring worker
# HEALTH_CHECK_INTERVAL_MINUTES=5

# Daily backup + restore
# BACKUP_DIR=./data/backups
# BACKUP_INTERVAL_HOURS=24
# BACKUP_DAILY_AT=03:00

# Explicit single-agent mode
# SINGLE_AGENT_MODE=true
# SINGLE_AGENT_SLUG=florencia

# Enforce per-agent access using x-agent-slug header
# AGENT_PERMISSIONS_ENABLED=true

# Runtime semaphore for free accounts
# ACCOUNT_EXHAUSTED_RESET_HOURS=24
# ACCOUNT_RUNTIME_RECOVER_INTERVAL_MINUTES=15
